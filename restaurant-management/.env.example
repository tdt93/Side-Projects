# =============================================================================
# Supabase → restaurant-management
# =============================================================================
#
# 1. Create a project at https://supabase.com/dashboard (or open an existing one)
#
# 2. Settings → Database → Database password (save it)
#
# 3. Settings → Database → Connection string → URI
#    Copy BOTH:
#    • Transaction pooler (port 6543)  → DATABASE_URL  (add ?pgbouncer=true if missing)
#    • Session pooler (port 5432)      → DIRECT_URL
#
# 4. Configure .env (pick one):
#
#    npm run db:configure -- --database-url "postgresql://..." --direct-url "postgresql://..."
#
#    npm run db:configure -- YOUR_PROJECT_REF YOUR_DB_PASSWORD eu-central-1
#
# 5. Apply schema + demo data:
#
#    npm run db:setup
#
# 6. Start app:
#
#    npm run dev
#
# Optional — menu image uploads (Settings → API):
#   NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...   (service_role key, keep secret)
#   Storage → New bucket → name: menu-images → Public bucket: ON
#
# =============================================================================

DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

SESSION_SECRET="change-me-to-a-32-char-secret-minimum!!"

NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
# When testing via Cloudflare Tunnel, prefer production mode (no dev HMR/WebSocket issues):
#   npm run dev:tunnel
# Then point cloudflared at http://localhost:3000
#
# Optional env for `next dev` through a tunnel (enables dev WebSocket/HMR):
# NEXT_PUBLIC_APP_URL="https://restaurant-test-live.tdtdev.net"
# DEV_TUNNEL_HOST="restaurant-test-live.tdtdev.net"
