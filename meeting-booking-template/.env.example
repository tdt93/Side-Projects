# MySQL (Cyber-Folk lub lokalnie)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"


# Sesja (min. 32 znaki)
SESSION_SECRET="zmien-na-losowy-ciag-co-najmniej-trzydziestu-dwoch-znakow"

# Opcjonalnie: szyfrowanie refresh tokenów Google (min. 8 znaków, najlepiej 32+)
CALENDAR_TOKEN_SECRET="osobny-tajny-klucz-do-kalendarza"

# Publiczny URL aplikacji rezerwacji (subdomena gabinetów)
# Produkcja: https://gabinety.trzymsie.pl
APP_URL="http://localhost:3000"

# Cloudflare Tunnel (np. trzymsiedemo.tdtdev.net → localhost:3000)
# Użyj npm run dev:tunnel, potem uruchom cloudflared na http://localhost:3000
# APP_URL="https://trzymsiedemo.tdtdev.net"
# DEV_TUNNEL_HOST="trzymsiedemo.tdtdev.net"

# Google Calendar OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Przelewy24 (REST API v1) — panel: https://panel.przelewy24.pl/
# Sandbox: ustaw P24_SANDBOX=true (domyślnie włączone gdy nie ustawione false)
P24_MERCHANT_ID=""
P24_POS_ID=""
P24_API_KEY=""
P24_CRC=""
# Domyślna cena gdy profil nie ma sessionPricePlnGrosze (grosze: 20000 = 200,00 PLN)
P24_DEFAULT_PRICE_PLN_GROSZE="20000"
# Opcjonalnie: ID metody „przelew bankowy” w P24 (np. e-Transfer Pocztowy24) — sprawdź w dokumentacji / panelu P24
# P24_BANK_TRANSFER_METHOD_ID="218"
P24_SANDBOX="true"

# E-mail (potwierdzenia rezerwacji)
# — Opcja A: Gmail (lub inny SMTP). Jeśli ustawisz SMTP_USER + SMTP_PASS, mają pierwszeństwo przed Resend.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
#
# — Opcja B: Resend (gdy brak SMTP)
RESEND_API_KEY=""
EMAIL_FROM="Gabinet <onboarding@resend.dev>"

# Hasła seed (opcjonalnie)
# SEED_ADMIN_PASSWORD="Admin123!"
# SEED_THERAPIST_PASSWORD="Therapist123!"
