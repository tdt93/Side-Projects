generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  // Generate on PC, upload src/generated/prisma — server cannot run prisma generate.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  THERAPIST
}

enum PaymentPolicy {
  PAY_BEFORE_BOOKING
  PAY_LATER_IN_PERSON
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  EXPIRED
}

model SiteSettings {
  id               String   @id @default(cuid())
  siteName         String   @default("Gabinet")
  /** JSON: { "footerCompany": { legalName, addressLine1, … } } — dane spółki w stopce */
  footerMarkdown   String?  @db.Text
  defaultSlotStep  Int      @default(30)
  pendingHoldMinutes Int    @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  passwordHash       String
  role               UserRole
  therapistProfileId String?           @unique
  therapistProfile   TherapistProfile? @relation(fields: [therapistProfileId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model TherapistProfile {
  id                String         @id @default(cuid())
  slug              String         @unique
  displayName       String
  title             String?
  taglineQuote      String?        @db.Text
  timezone          String         @default("Europe/Warsaw")
  avatarUrl         String?
  heroImageUrl      String?
  paymentPolicy     PaymentPolicy  @default(PAY_LATER_IN_PERSON)
  officeCity        String?
  officeAddressLine String?
  contactChannels   Json?
  bioLeadHtml       String?        @db.Text
  /** Cena sesji online w groszach (np. 20000 = 200,00 PLN). */
  sessionPricePlnGrosze Int?
  stripePriceId     String?
  receptionIntroHtml String?       @db.Text

  user     User?
  tags     SpecialtyOnProfile[]
  sections ContentSection[]
  testimonials Testimonial[]
  certificates CertificateAsset[]
  rules    AvailabilityRule[]
  meetingTypes MeetingType[]
  bookings Booking[]
  calendar CalendarConnection?
  messages ContactMessage[]

  @@index([officeCity])
}

model SpecialtyTag {
  id       String               @id @default(cuid())
  label    String               @unique
  profiles SpecialtyOnProfile[]
}

model SpecialtyOnProfile {
  profileId String
  tagId     String
  profile   TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tag       SpecialtyTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([profileId, tagId])
}

model ContentSection {
  id        String   @id @default(cuid())
  profileId String
  sortOrder Int      @default(0)
  heading   String
  bodyHtml  String   @db.Text
  profile   TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Testimonial {
  id        String   @id @default(cuid())
  profileId String
  authorName String
  body      String   @db.Text
  sortOrder Int      @default(0)
  profile   TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model CertificateAsset {
  id        String   @id @default(cuid())
  profileId String
  imageUrl  String
  caption   String?
  sortOrder Int      @default(0)
  profile   TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

/// dayOfWeek: 0 = Sunday … 6 = Saturday (JavaScript getUTCDay when interpreted in local tz — app uses therapist timezone for interpretation)
model AvailabilityRule {
  id        String   @id @default(cuid())
  profileId String
  dayOfWeek Int
  startTime String
  endTime   String
  profile   TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model MeetingType {
  id              String   @id @default(cuid())
  profileId       String
  label           String
  durationMinutes Int      @default(50)
  sortOrder       Int      @default(0)
  profile         TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  bookings        Booking[]

  @@index([profileId])
}

model Booking {
  id                    String        @id @default(cuid())
  profileId             String
  meetingTypeId         String?
  start                 DateTime
  end                   DateTime
  guestName             String
  guestEmail            String
  notes                 String?       @db.Text
  status                BookingStatus @default(CONFIRMED)
  stripeSessionId       String?
  stripePaymentIntentId String?
  /** Id sesji w Przelewy24 (zwykle = id rezerwacji). */
  p24SessionId          String?
  /** orderId zwrócony przez Przelewy24 po udanej płatności. */
  p24OrderId            Int?
  /** Zgoda RODO / udostępnienie danych terapeucie — ustawiana przy płatności online */
  consentPrivacyTherapistAt DateTime?
  consentMarketingEmail     Boolean   @default(false)
  googleEventId         String?
  emailSentAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  profile     TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  meetingType MeetingType?     @relation(fields: [meetingTypeId], references: [id], onDelete: SetNull)

  @@index([profileId, start])
  @@index([guestEmail])
  @@index([status, start])
}

model CalendarConnection {
  id              String   @id @default(cuid())
  profileId       String   @unique
  provider        String   @default("GOOGLE")
  refreshTokenEnc String   @db.Text
  calendarId      String?
  lastSyncAt      DateTime?
  syncPullEnabled Boolean  @default(true)
  syncPushEnabled Boolean  @default(true)
  profile         TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  profileId String
  name      String
  email     String
  body      String   @db.Text
  createdAt DateTime @default(now())
  profile   TherapistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}
