{
  "name": "meeting-booking-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:tunnel": "next build --turbopack && next start -H 0.0.0.0 -p 3000",
    "build": "next build --turbopack",
    "build:webpack": "next build --webpack",
    "build:hosting": "node scripts/build-hosting.js",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "node scripts/postinstall-prisma.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "googleapis": "^171.4.0",
    "iron-session": "^8.0.4",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "^6.10.0",
    "zod": "^4.3.6",
    "prisma": "^6.19.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
