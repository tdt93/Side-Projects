# Copy this file to ".env" in this folder (airtable-viewer) for local development.
# If you keep vars in the parent folder instead (e.g. Side Projects/.env), the server still loads them
# for any keys missing here — but putting LIST_VIEW and AIRTABLE_* here is clearest.
# On Render, add each variable in the dashboard (Environment) — do not paste tokens into .env.example.

# Session signing (use a long random string in production)
SESSION_SECRET=

# SQLite database file (default: ./data/app.db). Use persistent disk on your host.
# For managed hosting without a persistent disk, prefer PostgreSQL and swap the db layer.
DATABASE_PATH=./data/app.db

# Airtable: https://airtable.com/create/tokens — data.records:read
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# --- List table (backend only; no UI) ---
# Airtable field name: each user's partner_filter in the users table must match this field's value (case-insensitive).
# Rows with "BRAK" or empty partner are never shown.
AIRTABLE_PARTNER_GROUP_FIELD=PARTNER (from Klienty)
#
# Comma-separated field NAMES in column order. Must match keys (see server.js):
# fullname, dob, passportNr, case, documentSubmittedDate, fingerprintDate,
# decisionExpectedDate, collectionCardDate
# Example (use your real Airtable field names, in this order):
# AIRTABLE_LIST_VIEW_FIELDS=Fullname,Date of birth,Passport nr.,Case ref.,Document submited date,Fingerprint-date,Decision expected date,Collection card date
AIRTABLE_LIST_VIEW_FIELDS=

# Optional: Google sign-in (only emails you add to the database can complete login)
# GOOGLE_CALLBACK_URL must match the URI configured in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- Users / partner_filter (SQLite) ---
# When adding a user, pass the partner as the last argument (see npm run user:add). That value is stored in users.partner_filter.
# To change it later:
#   npm run user:partner -- "user@example.com" "Exact label as in Airtable"
#   npm run user:partner -- "user@example.com" ""   # clear partner_filter
# Or SQLite (paths relative to airtable-viewer):
#   sqlite3 data/app.db "UPDATE users SET partner_filter = 'Exact label' WHERE lower(email) = 'user@example.com';"
#   sqlite3 data/app.db "UPDATE users SET partner_filter = NULL WHERE lower(email) = 'user@example.com';"
# (NULL means the user sees no rows until partner_filter is set.)
