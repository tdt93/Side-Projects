# Session signing (use a long random string in production)
SESSION_SECRET=

# SQLite database file (default: ./data/app.db). Use persistent disk on your host.
# For managed hosting without a persistent disk, prefer PostgreSQL and swap the db layer.
DATABASE_PATH=./data/app.db

# Airtable: https://airtable.com/create/tokens — data.records:read
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# Optional: Google sign-in (only emails you add to the database can complete login)
# GOOGLE_CALLBACK_URL must match the URI configured in Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
