# Copy this file to ".env" in this folder (airtable-viewer) for local development.
#
# Render.com: if your Git repo root is the parent folder (e.g. "Side Projects") and this app lives in
# airtable-viewer/, set the service "Root Directory" to airtable-viewer, or use ../render.yaml as a Blueprint.
# If you keep vars in the parent folder instead (e.g. Side Projects/.env), the server still loads them
# for any keys missing here — but putting LIST_VIEW and AIRTABLE_* here is clearest.
# On Render, add each variable in the dashboard (Environment) — do not paste tokens into .env.example.

# Public URL of this app (https, no trailing slash). Production: https://partner.a2dsolutions.pl
# (Optional) Used for logging; sign-in is email + phone against the Partner table in Airtable.
PUBLIC_APP_URL=https://partner.a2dsolutions.pl

# Session signing: secret key used to cryptographically sign the session cookie so users stay logged in
# securely. Change it if leaked; use a long random string in production (not related to ADMIN_USER_LIST_SECRET).
SESSION_SECRET=

# Optional: browser user list at /admin-users.html — send the same value as HTTP header X-Admin-Secret (never share publicly)
ADMIN_USER_LIST_SECRET=

# SQLite database file (default: ./data/app.db). Use persistent disk on your host.
# For managed hosting without a persistent disk, prefer PostgreSQL and swap the db layer.
DATABASE_PATH=./data/app.db

# Airtable: https://airtable.com/create/tokens — data.records:read
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# --- Partner login (Airtable table of partners) ---
# Table name exactly as in Airtable. Each row: login Email + Kontakt (phone) must match what the user enters; partner column must match Sprawy/Klienty partner values.
AIRTABLE_PARTNERS_TABLE=
# Field names on that table (defaults shown):
# AIRTABLE_PARTNER_EMAIL_FIELD=Email
# AIRTABLE_PARTNER_PHONE_FIELD=Kontakt
# Value that matches AIRTABLE_PARTNER_GROUP_FIELD / AIRTABLE_CLIENTS_PARTNER_FIELD on cases & clients (same spelling as in those rows).
# AIRTABLE_PARTNER_LABEL_FIELD=Partner

# --- List table (backend only; no UI) ---
# Airtable field name on the cases (Sprawy) table: must match AIRTABLE_PARTNER_LABEL_FIELD on the Partner row (case-insensitive compare).
# Rows with "BRAK" or empty partner are never shown.
AIRTABLE_PARTNER_GROUP_FIELD=
#
# Comma-separated field NAMES in column order. Must match keys (see server.js):
# fullname, dob, passportNr, case, documentSubmittedDate, fingerprintDate,
# decisionExpectedDate, collectionCardDate
# Example (use your real Airtable field names, in this order):
# AIRTABLE_LIST_VIEW_FIELDS=Fullname,Date of birth,Passport nr.,Case ref.,Document submited date,Fingerprint-date,Decision expected date,Collection card date
AIRTABLE_LIST_VIEW_FIELDS=

# --- Client list ("Klienty" table) ---
# Table name in Airtable (URL-encoded name is fine)
AIRTABLE_CLIENTS_TABLE=
# Partner column on Klienty (usually PARTNER). Sprawy often uses a linked field name like "PARTNER (from Klienty)" — do not reuse that here.
AIRTABLE_CLIENTS_PARTNER_FIELD=
# Four comma-separated Airtable field NAMES in order: name, date of birth, passport, card expiry
# (maps to UI keys fullname, dob, passportNr, cardExpiredDate)
# AIRTABLE_CLIENT_LIST_FIELDS=Full name,Date of birth,Passport,Card valid until
AIRTABLE_CLIENT_LIST_FIELDS=

# Cache duration for full-table Airtable fetches (seconds). Same TTL for cases + clients tables; reduces rate-limit risk.
AIRTABLE_CACHE_TTL_SEC=120

# --- API rate limits (per client IP; Render: trust proxy is enabled) ---
# Unauthenticated /api/* requests per minute (default 120). /api/health is exempt; logged-in users skip this limiter.
# RATE_LIMIT_API_PER_MIN=120
# Login: max POST /api/login attempts per window (default 15 per 15 minutes).
# RATE_LIMIT_LOGIN_MAX=15
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# Admin routes (X-Admin-Secret): default 40 per 15 minutes.
# RATE_LIMIT_ADMIN_MAX=40
# RATE_LIMIT_ADMIN_WINDOW_MS=900000

# --- Users / partner_filter (SQLite; optional / admin tools only) ---
# Sign-in no longer uses this table — partners log in via AIRTABLE_PARTNERS_TABLE. SQLite remains for sessions and optional admin scripts.
# When adding a user, pass the partner as the last argument (see npm run user:add). That value is stored in users.partner_filter.
# To change it later:
#   npm run user:partner -- "user@example.com" "Exact label as in Airtable"
#   npm run user:partner -- "user@example.com" ""   # clear partner_filter
# Or SQLite (paths relative to airtable-viewer):
#   sqlite3 data/app.db "UPDATE users SET partner_filter = 'Exact label' WHERE lower(email) = 'user@example.com';"
#   sqlite3 data/app.db "UPDATE users SET partner_filter = NULL WHERE lower(email) = 'user@example.com';"
# (NULL means the user sees no rows until partner_filter is set.)
